#!/bin/sh
set -eu

# Spin FM is installed as application-private source. Avoid creating bytecode
# beside either a source checkout or the read-only system installation.
export PYTHONDONTWRITEBYTECODE=1

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
source_main="$script_dir/../main.py"

if [ -f "$source_main" ]; then
    exec python3 -B "$source_main" "$@"
fi

exec python3 -B /usr/share/spin-fm/main.py "$@"
