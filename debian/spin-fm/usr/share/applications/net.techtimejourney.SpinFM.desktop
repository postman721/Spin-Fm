[Desktop Entry]
Type=Application
Name=Spin FM
GenericName=File Manager
Comment=Browse and manage files with tabs and removable-device support
TryExec=spin-fm
Exec=spin-fm %U
Icon=spin-fm
Terminal=false
Categories=System;FileTools;FileManager;Utility;
MimeType=inode/directory;
StartupNotify=true
StartupWMClass=Spin FM
Keywords=files;folders;browser;storage;USB;
